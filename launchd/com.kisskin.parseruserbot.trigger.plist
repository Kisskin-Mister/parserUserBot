<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.kisskin.parseruserbot.trigger</string>

    <key>WorkingDirectory</key>
    <string>/Users/kisskin/PycharmProjects/parserUserBot</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/kisskin/PycharmProjects/parserUserBot/.venv/bin/python</string>
        <string>/Users/kisskin/PycharmProjects/parserUserBot/trigger_worker.py</string>
        <string>--once</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
