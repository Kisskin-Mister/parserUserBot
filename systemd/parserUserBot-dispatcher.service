[Unit]
Description=parserUserBot — callback dispatcher (sends outbox entries to OpenClaw gateway)
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=oneshot
User=kisskin
WorkingDirectory=/mnt/ssd/projects/parserUserBot
ExecStart=/usr/bin/python3 /mnt/ssd/projects/parserUserBot/callback_dispatcher.py --once
EnvironmentFile=/mnt/ssd/projects/parserUserBot/.env

StandardOutput=journal
StandardError=journal
