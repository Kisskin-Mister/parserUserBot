[Unit]
Description=parserUserBot — callback dispatcher (sends callback_outbox entries to OpenClaw gateway)
After=network-online.target postgresql.service
Wants=network-online.target postgresql.service

[Service]
Type=oneshot
User=parseruserbot
WorkingDirectory=/opt/parserUserBot
EnvironmentFile=/opt/parserUserBot/.env
ExecStart=/opt/parserUserBot/.venv/bin/python /opt/parserUserBot/callback_dispatcher.py --once
StandardOutput=journal
StandardError=journal
