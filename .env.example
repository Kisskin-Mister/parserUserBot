# Telegram API (get from my.telegram.org)
API_ID=12345678
API_HASH=0123456789abcdef0123456789abcdef
PHONE_NUMBER=+1234567890
# Chat where bot will log applications
LOG_CHAT_ID=-1001234567890

# Path to your resume file
RESUME_PATH=resume.pdf

# Postgres Configuration
# Format: postgresql://user:password@localhost:5432/tg_hr
DATABASE_URL=postgresql://postgres:password@localhost:5432/tg_hr

# Ultra-light callback trigger worker
# What to watch: vacancies | news
TRIGGER_ENTITY_TYPE=vacancies
# Max rows in one callback batch
TRIGGER_BATCH_LIMIT=50
# Used only in long-running mode (not needed for systemd timer)
TRIGGER_POLL_INTERVAL_SEC=30
TRIGGER_LOG_LEVEL=INFO

# OpenClaw callback target
OPENCLAW_CALLBACK_SESSION_KEY=agent:main:main
# Optional: if omitted, openclaw will use configured default gateway
OPENCLAW_GATEWAY_URL=
# Optional: if gateway requires token and env-based auth is preferred
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_CALLBACK_TIMEOUT_MS=10000
