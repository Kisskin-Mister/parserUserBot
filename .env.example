# Telegram user account credentials from https://my.telegram.org/apps
API_ID=your_api_id
API_HASH=your_api_hash
PHONE_NUMBER=your_phone_number

# Pyrogram session name/path. With Docker this is stored in the telegram_session volume.
SESSION_NAME=session/my_account

# PostgreSQL. Docker Compose uses these to build the connection string.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=parseruserbot
POSTGRES_USER=parseruserbot
POSTGRES_PASSWORD=change_me

# Management API
APP_PORT=8000
ADMIN_TOKEN=token_here

# Forwarding behavior: forward keeps Telegram attribution; copy sends plain text copy.
FORWARD_MODE=forward
IGNORE_PRIVATE_CHATS=true
# Comma-separated global deny-list. Useful for news channels or noisy chats.
EXCLUDED_CHAT_IDS=

# OpenAI-compatible classifier API for AI mode.
# For local models (LM Studio/Ollama/vLLM/llama.cpp server), use local base_url and OPENAI_API_KEY=local.
OPENAI_BASE_URL=http://host.docker.internal:1234/v1
OPENAI_API_KEY=local
OPENAI_MODEL=local-model

# Legacy compatibility options. New installs usually do not need these.
LOG_CHAT_ID=
OWNER_USERNAME=
NEWS_CHAT_ID=
RESUME_PATH=
