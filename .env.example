# Telegram API credentials from https://my.telegram.org/apps
# Keep real values only in .env. Never commit .env or *.session files.
API_ID=your_api_id
API_HASH=your_api_hash
PHONE_NUMBER=your_phone_number

# Telegram destinations
# LOG_CHAT_ID is used by mcp_server.py post and is ignored by the message parser.
LOG_CHAT_ID=-1001234567890
# OWNER_USERNAME receives recruiter private-message forwards and status reports.
OWNER_USERNAME=your_telegram_username
# NEWS_CHAT_ID is used by mcp_server.py repost_news.
NEWS_CHAT_ID=-1001234567890

# PostgreSQL database used by database.py (asyncpg).
DATABASE_URL=postgresql://parseruserbot:change_me@localhost:5432/parseruserbot

# Resume optionally sent by mcp_server.py apply when the file exists.
RESUME_PATH=resumes/resume_main.pdf

# Trigger worker: vacancies or news, batch size, long-running polling interval.
TRIGGER_ENTITY_TYPE=vacancies
TRIGGER_BATCH_LIMIT=50
TRIGGER_POLL_INTERVAL_SEC=30
TRIGGER_LOG_LEVEL=INFO

# Callback dispatcher / OpenClaw gateway integration.
OPENCLAW_CALLBACK_SESSION_KEY=agent:main:main
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_CALLBACK_TIMEOUT_MS=10000
OPENCLAW_BIN=
DISPATCHER_LOG_LEVEL=INFO

# Legacy Rich dashboard spool counters only; DB callback_outbox is the real dispatcher queue.
OPENCLAW_CALLBACK_SPOOL_DIR=runtime/callback_spool
OPENCLAW_CALLBACK_SENT_DIR=runtime/callback_sent
OPENCLAW_CALLBACK_FAILED_DIR=runtime/callback_failed
